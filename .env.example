# OSCAR MariaDB/MySQL connection for local MCP use.
# Copy this file to .env and fill in the credentials. Do not commit .env.

OSCAR_MCP_MYSQL_HOST=172.16.172.167
OSCAR_MCP_MYSQL_PORT=3306
OSCAR_MCP_MYSQL_DATABASE=oscar_15
OSCAR_MCP_MYSQL_USER=
OSCAR_MCP_MYSQL_PASSWORD=

# Optional connection tuning.
OSCAR_MCP_CONNECT_TIMEOUT=5
OSCAR_MCP_READ_TIMEOUT=30
OSCAR_MCP_WRITE_TIMEOUT=30
